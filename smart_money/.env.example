# Moralis API
MORALIS_API_KEY=your_moralis_api_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here   # Send /start to your bot to find this

# Database
DB_PATH=smart_money.db               # SQLite file path (relative to project root)

# Chains to scan (comma-separated: eth,bsc,polygon,base,arbitrum,optimism)
ENABLED_CHAINS=eth,bsc,polygon,base

# Moralis plan tier: starter | pro | business  (affects CU/s budget)
MORALIS_PLAN=starter

# Scanning cadence (seconds) - tune per your API limits
SCAN_INTERVAL_WALLETS=30
SCAN_INTERVAL_TOKENS=60
SCORE_UPDATE_INTERVAL=300
TOP100_SYNC_INTERVAL=600
GRAPH_UPDATE_INTERVAL=1800

# Signal thresholds
SMART_WALLET_SCORE_THRESHOLD=70
COORDINATED_BUY_MIN_WALLETS=3
COORDINATED_BUY_WINDOW_HOURS=4
WHALE_MOVE_MIN_USD=50000

# Top-N wallets to maintain
TOP_WALLET_COUNT=100

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/smart_money.log

# Seed tokens for initial wallet discovery (Ethereum contract addresses, comma-separated)
SEED_TOKENS=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2
